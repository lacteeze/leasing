# App URL (no trailing slash). On Vercel, VERCEL_URL is used automatically if unset.
AUTH_URL=http://localhost:4173

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only secret key (sb_secret_… or legacy service_role JWT). Required for reliable manager deletes.
SUPABASE_SECRET_KEY=

# Google Maps — https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Pingram — https://pingram.io
PINGRAM_API_KEY=
PINGRAM_BASE_URL=https://api.ca.pingram.io
PINGRAM_EMAIL_TYPE=viewing_request_received
EMAIL_SENDER_NAME=Canary
EMAIL_SENDER_EMAIL=notifications@canarypm.ca
